<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0; padding:0; width:100%; background-color:#f4f6f8;">
    <tr>
        <td align="center" style="padding:24px 12px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-collapse:collapse; border:1px solid #e5e7eb;">
                <tr>
                    <td style="padding:32px 24px 24px 24px; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:24px; color:#1f2937;">
                        <p style="margin:0 0 16px 0;">Hello,</p>

                        <p style="margin:0 0 16px 0;">
                            Use the button below to log in to <strong>MyEspacio</strong> @ {{ website_owner }}.
                        </p>

                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:24px 0;">
                            <tr>
                                <td align="center" bgcolor="#2563eb" style="border-radius:6px;">
                                    <a href="{{ domain_root }}/login/{{ user.magicLink }}"
                                       style="display:inline-block; padding:14px 22px; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:20px; font-weight:bold; color:#ffffff; text-decoration:none; border-radius:6px;">
                                        Log in to MyEspacio
                                    </a>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:0 0 8px 0; font-size:14px; line-height:22px; color:#4b5563;">
                            If the button doesn't work, copy and paste this link into your browser:
                        </p>

                        <p style="margin:0 0 20px 0; word-break:break-all; font-size:14px; line-height:22px;">
                            <a href="{{ domain_root }}/login/{{ user.magicLink }}" style="color:#2563eb; text-decoration:underline;">
                                {{ domain_root }}/login/{{ user.magicLink }}
                            </a>
                        </p>

                        <div style="margin:24px 0; padding:16px; background-color:#f9fafb; border:1px solid #e5e7eb; border-radius:6px;">
                            <p style="margin:0 0 8px 0; font-size:14px; line-height:22px; color:#4b5563;">
                                Alternatively, enter this activation code in the login screen:
                            </p>
                            <p style="margin:0; font-family:Courier, monospace; font-size:24px; line-height:32px; font-weight:bold; letter-spacing:2px; color:#111827;">
                                {{ user.phoneCode }}
                            </p>
                        </div>

                        <p style="margin:0 0 16px 0; font-size:14px; line-height:22px; color:#4b5563;">
                            If you did not request this login, you can safely ignore this message.
                        </p>

                        <p style="margin:24px 0 0 0;">Thanks,</p>
                        <p style="margin:4px 0 0 0; font-weight:bold;">{{ website_owner }}</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
